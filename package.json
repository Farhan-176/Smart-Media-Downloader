{
  "name": "smart-media-downloader",
  "version": "1.0.0",
  "description": "Production-quality desktop download manager with segmented multi-connection engine",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "test:download": "node ./scripts/test_download.js",
    "test:video": "node ./scripts/test_video_download.js"
  },
  "keywords": [
    "download",
    "manager",
    "electron",
    "multi-connection",
    "segmented"
  ],
  "author": "Smart Media Downloader Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "ffmpeg-static": "^5.3.0",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.smartmedia.downloader",
    "productName": "Smart Media Downloader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/ffmpeg.exe",
      "**/node_modules/yt-dlp-exec/bin/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
